
pkg PHireScript.Samples28

use PHireScript.Samples28.{
    UserCredentials
    User as UserAccess,
    Authenticator,
    Another,
    Logger
}

external Symfony\Component\DependencyInjection\Loader\GlobFileLoader

class AuthenticatorClass with Logger as singleton implements Authenticator, Another {
    save?(Array data): Bool {
        return true
    }

    delete!(): Void {
        return
    }

    getCompleteUserName(): String|Null {
        return null
    }

    authenticate(Null|UserCredentials credentials = null): Bool {
        return true
    }

    logout(): Void {
        return
    }

    returnNull(): Null {
        return null
    }

    returnStringSingle(): String {
        return 'single quotes'
    }

    returnStringDouble(): String {
        return "double quotes"
    }

    returnFloat(): Float {
        return 15.2
    }

    returnInt(): Int {
        return 10
    }

    returnArrayEmpty(): Array {
        return []
    }

    returnArrayComplete(): Array {
        return ['example': ['another', 'array']]
    }

    returnObjectEmpty(): Object {
        return {}
    }

    returnObject(): Object {
        return { 'test': 1 }
    }
}
