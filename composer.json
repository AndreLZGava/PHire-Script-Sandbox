{
  "name": "phire-script/sandbox",
  "description": "This is a sandbox for PHire Script",
  "type": "project",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "PHireScript\\Orchestrator\\": "orchestrator",
      "Sandbox\\Samples\\": "samples",
      "PHireScript\\Sandbox\\": "src/output",
      "PHireScript\\": "phirescript/src"
    }
  },
  "minimum-stability": "dev",
  "require": {
    "phire-script/phire-script": "*"
  },
  "repositories": [
    {
      "type": "path",
      "url": "./phirescript"
    }
  ],
  "scripts": {
    "build": "./vendor/phirescript/bin/build",
    "debug": "./vendor/phirescript/bin/debug",
    "snapshot": "./vendor/phirescript/bin/snapshot",
    "watch": "./vendor/phirescript/bin/watch"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5"
  }
}
